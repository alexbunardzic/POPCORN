<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= org.name %> — POPCORN Board</title>
  <link rel="stylesheet" href="/style.css">
  <script src="/htmx.min.js" defer></script>
</head>
<body>
  <header>
    <h1>POPCORN Flow — <%= org.name %></h1>
    <nav>
      <span><%= user.email %> (<%= user.role %>)</span>
      <form method="POST" action="/auth/logout" style="display:inline">
        <button type="submit">Sign out</button>
      </form>
    </nav>
  </header>

  <main class="board-wrap"
        hx-trigger="boardChange from:body"
        hx-get="/orgs/<%= org.slug %>/board"
        hx-target="this"
        hx-swap="innerHTML">
    <%- include('../partials/board/board-inner', { rows, ticketMap, org, user, wipCount, wipLimit }) %>
  </main>
</body>
</html>
