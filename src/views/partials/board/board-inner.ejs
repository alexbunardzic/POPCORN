<div class="board-grid">

  <%# ── Column headers ── %>
  <div class="board-col-header board-col-header--problems">Problems</div>
  <div class="board-col-header board-col-header--options">Options</div>
  <div class="board-col-header board-col-header--possible">Possible</div>
  <div class="board-col-header board-col-header--committed">Committed</div>
  <div class="board-col-header board-col-header--ongoing">
    Ongoing
    <% if (wipCount >= wipLimit) { %><span class="wip-badge">WiP limit!</span><% } %>
  </div>
  <div class="board-col-header board-col-header--review">Review</div>
  <div class="board-col-header board-col-header--next">Next</div>

  <%# ── Swimlane rows ── %>
  <% for (let i = 0; i < rows.length; i++) { %>
    <% if (i > 0) { %><div class="board-divider"></div><% } %>
    <%- include('row', { row: rows[i], org, user, wipCount, wipLimit, ticketMap }) %>
  <% } %>

  <%# ── Empty state ── %>
  <% if (rows.length === 0) { %>
  <div class="board-empty">
    <p>No problems yet. Add your first problem below to get started.</p>
  </div>
  <% } %>

  <%# ── Add problem ── %>
  <div class="board-add-problem">
    <form hx-post="/orgs/<%= org.slug %>/tickets" hx-swap="none">
      <input type="hidden" name="column" value="problems">
      <input type="text" name="title" placeholder="Describe a new problem…" required>
      <button type="submit">+ Add Problem</button>
    </form>
  </div>

</div>
